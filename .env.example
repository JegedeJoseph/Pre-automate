# .env.example
# Copy this file to .env and fill in your values
# DO NOT commit .env to Git (it's in .gitignore)

# Google Sheets Integration
# Get this from https://console.cloud.google.com/
GOOGLE_CREDENTIALS_JSON='{"type": "service_account", "project_id": "YOUR_PROJECT", ...}'

# Your Gmail for digest emails
YOUR_GMAIL=your.email@gmail.com

# Gmail app password (enable 2FA, then generate app password)
GMAIL_APP_PASSWORD=your_app_password

# Anthropic Claude API for cover letters
ANTHROPIC_API_KEY=sk-ant-...

# Applicant information (for form filling)
APPLICANT_NAME="Your Full Name"
APPLICANT_EMAIL=your.email@gmail.com

# Optional: LinkedIn session cookie (future use)
# LINKEDIN_SESSION_ID=

# Optional: Indeed session cookie (future use)
# INDEED_SESSION_ID=

# Optional: Google Sheets ID (for email digest link)
SHEET_ID=your_sheet_id_here
