# Google Sheets Configuration
# Set GOOGLE_APPLICATION_CREDENTIALS to either:
# 1. Path to your Google service account JSON file
# 2. Your Google service account JSON as a string
GOOGLE_APPLICATION_CREDENTIALS=
SPREADSHEET_ID=

# Scraper Settings
HEADLESS_BROWSER=true
BROWSER_TIMEOUT=30000
WAIT_TIME=10000
DEFAULT_PAGES_TO_SCRAPE=3

# Resume File Path
RESUME_FILE_PATH=./data/sample_resume.txt

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
